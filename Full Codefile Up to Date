#Race Categorization and variable creation
chas_clean <- chas_clean %>% 
  mutate(Native_American = RACE1,
         Asian = RACE2,
         Black_or_African_American = RACE3,
         Hispanic = RACE4,
         Middle_Eastern = RACE5,
         Pacific_Islander = RACE6,
         White = RACE7,
         Other = RACE8)

chas_clean <- chas_clean %>% 
  mutate(n_race = rowSums(cbind(
    Native_American == 1,
    Asian == 1,
    Black_or_African_American == 1,
    Hispanic == 1,
    Middle_Eastern == 1,
    Pacific_Islander == 1,
    White == 1,
    Other == 1)),
    race_exclusive = case_when(
      n_race >= 2 ~ "Multiracial",
      n_race == 0 ~ "Unknown",
      Native_American == 1 ~ "American Indian or Alaskan native",
      Asian == 1 ~ "Asian",
      Black_or_African_American == 1 ~ "Black",
      Hispanic == 1 ~ "Hispanic",
      Middle_Eastern == 1 ~ "Middle Eastern",
      Pacific_Islander == 1 ~ "Pacific Islander",
      White == 1 ~ "White",
      Other == 1~ "Other"))
table(chas_clean$race_exclusive)

ggplot(chas_clean, aes(x = race_exclusive)) +
  geom_bar(fill = "lightblue", colour = "white") +
  labs(title    = "Race Distribution of CHAS Respondents",
       x        = "Reported Race",
       y        = "Count",
       caption  = "") +
  theme_minimal()

