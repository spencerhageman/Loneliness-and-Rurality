
library(tidyverse)
library(ggplot2)
library(scales)


chas <- read_csv("/Users/spencerhageman/Documents/Research Methods/CHAS25_RESEARCH_CSU.csv", na = c("", "NA", "."))

#-------------------------------------------------------------------------------------------------------------------------

# Filter and Recode Loneliness and Education Variables
# Loneliness questions: Column KM "SOCIAL_COMPANION" (SC1_A), Column KN "SOCIAL_LEFTOUT"(SC2), Column KO "SOCIAL_ISOLATED"(SC3)
# Exclude: "." (missing / period) and 77, 98, 99
# Recode: 1 → "Not Lonely"; 2 or 3 → "Lonely"

# Convert to numeric, converting "." to NA 
chas1 <- chas %>%
  mutate(across(c(SOCIAL_COMPANION, SOCIAL_LEFTOUT, SOCIAL_ISOLATED),
                ~ as.numeric(.x)))

# Exclude rows where any loneliness question = NA or 77 or 98 or 99
 n_before <- nrow(chas1)

 chas_clean <- chas1 %>%
      filter(
        !is.na(SOCIAL_COMPANION), !SOCIAL_COMPANION %in% c(77, 98, 99),
        !is.na(SOCIAL_LEFTOUT), !SOCIAL_LEFTOUT %in% c(77, 98, 99),
        !is.na(SOCIAL_ISOLATED), !SOCIAL_ISOLATED %in% c(77, 98, 99)
      )

n_after <- nrow(chas_clean)
cat(n_before)
cat(n_before - n_after)
cat(n_after)
chas_clean$SOCIAL_COMPANION
# Binary recode (bin)
 chas_clean <- chas_clean %>%
   mutate(
     SOCIAL_COMPANION_bin = if_else(SOCIAL_COMPANION == 1, "Not Lonely", "Lonely"),
     SOCIAL_LEFTOUT_bin = if_else(SOCIAL_LEFTOUT == 1, "Not Lonely", "Lonely"),
     SOCIAL_ISOLATED_bin = if_else(SOCIAL_ISOLATED == 1, "Not Lonely", "Lonely"),

     # Factor versions
     SOCIAL_COMPANION_fct = factor(SOCIAL_COMPANION_bin,
                          levels = c("Not Lonely", "Lonely")),
     SOCIAL_LEFTOUT_fct = factor(SOCIAL_LEFTOUT_bin,
                          levels = c("Not Lonely", "Lonely")),
     SOCIAL_ISOLATED_fct = factor(SOCIAL_ISOLATED_bin,
                          levels = c("Not Lonely", "Lonely"))
   )
cat(chas_clean$SOCIAL_COMPANION_bin)
chas_clean1 <- chas_clean %>%
  mutate(
    SOCIAL_COMPANION_bin = ifelse(SOCIAL_COMPANION_bin == "Not Lonely", 1, 0),
    SOCIAL_LEFTOUT_bin   = ifelse(SOCIAL_LEFTOUT_bin   == "Not Lonely", 1, 0),
    SOCIAL_ISOLATED_bin  = ifelse(SOCIAL_ISOLATED_bin  == "Not Lonely", 1, 0)
  )
#----------------------------------------------------------------------------------------------------------------------- 
 
# Education binary re-code
# Original CHAS education categories
#   1 = Less than high school
#   2 = High school diploma or GED
#.  3 = Some College (no degree)
#   4 = Associate's Degree
#   5 = College graduate (Bachelor's degree)
#   6 = Post-graduate degree
#
# Recode: 1-3 -> "No college degree"
#         4-6 -> "College degree or more"

 chas_clean <- chas_clean %>%
   mutate(
     education_bin = case_when(
       EDUCATION %in% 1:3 ~ "No college degree",
       EDUCATION %in% 4:6 ~ "College degree or more",
       TRUE               ~ NA_character_
     ),
     education_fct = factor(education_bin,
                            levels = c("No college degree", "College degree or more"))
   )

 
 print(table(chas_clean$education_bin, useNA = "always"))

 #visulaization of eduaction distribution
 ggplot(chas_clean, aes(x = education_bin)) +
   geom_bar(fill = "lightblue", colour = "white") +
   labs(title    = "Education Category Distribution",
        x        = "Education Category",
        y        = "Count",
        caption  = "") +
   theme_minimal()

