#Preliminary Models and sensitivity analysis for response variable (does not include interaction term for age, which will be evaluated for final model)
# model1 uses response variable SOCIAL_COMPANION_bin
pmodel1 <- glm(SOCIAL_COMPANION_bin ~ urban_cat + age_cat + race_exclusive + sex_exclusive + education_bin + gender_cat, 
               data = chas_clean1,
               family = binomial)

# model2 uses response variable SOCIAL_LEFTOUT_bin
pmodel2 <- glm(SOCIAL_LEFTOUT_bin ~ urban_cat + age_cat + race_exclusive + sex_exclusive + education_bin + gender_cat, 
               data = chas_clean1,
               family = binomial)

# model3 uses response variable SOCIAL_ISOLATED_bin
pmodel3 <- glm(SOCIAL_ISOLATED_bin ~ urban_cat + age_cat + race_exclusive + sex_exclusive + education_bin + gender_cat, 
               data = chas_clean1,
               family = binomial)
#model summaries
summary(pmodel1)
summary(pmodel2)
summary(pmodel3)
