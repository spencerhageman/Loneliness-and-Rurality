  "Phillips",       1,  "Rural",
  "Sedgwick",       1,  "Rural",
  "Morgan",         1,  "Rural",
  # ── HSR 2: Larimer (Urban) ────────────────────────────────
  "Larimer",        2,  "Urban",
  # ── HSR 3: Douglas (Urban) ────────────────────────────────
  "Douglas",        3,  "Urban",
  # ── HSR 4: El Paso (Urban) ────────────────────────────────
  "El Paso",        4,  "Urban",
  # ── HSR 5: East Central (Rural) ───────────────────────────
  "Lincoln",        5,  "Rural",
