# ============================================================
# SECTION 3: MAPS
# ============================================================

# ── 5a. Download Colorado county shapefiles ───────────────────
co_counties_sf <- counties(state = "CO", cb = TRUE, resolution = "5m") %>%
  st_transform(crs = 26913)   # NAD83 / UTM Zone 13N – good for Colorado

# Standardise county name column and join lookup
co_counties_sf <- co_counties_sf %>%
  rename(county = NAME) %>%
  left_join(county_hsr_lookup, by = "county")

# HSR centroids for labelling
hsr_centroids <- co_counties_sf %>%
  group_by(hsr) %>%
  summarise(geometry = st_union(geometry)) %>%
  st_centroid() %>%
  left_join(hsr_data %>% select(hsr, hsr_name), by = "hsr")


# ── Colour palettes ───────────────────────────────────────────
county_palette <- c(
  "Urban"        = "#2166AC",   # blue
  "Rural Resort" = "#74C476",   # green
  "Rural"        = "#D6604D"    # red-orange
)

hsr_palette <- setNames(
  colorRampPalette(c("#E8F4F8", "#084594"))(21),
  1:21
)


# ────────────────────────────────────────────────────────────
# MAP 1 – County-level Rural / Rural Resort / Urban
# ────────────────────────────────────────────────────────────

# Compute county centroids for labels
county_centroids <- co_counties_sf %>%
  st_centroid()

map1 <- ggplot(co_counties_sf) +
  geom_sf(aes(fill = county_type), colour = "white", linewidth = 0.3) +
  geom_sf_text(data = county_centroids,
               aes(label = county),
               size = 1.7, colour = "white", fontface = "bold") +
  scale_fill_manual(
    values   = county_palette,
    name     = "County Classification",
    na.value = "grey80"
  ) +
  labs(
    title    = "Colorado Counties by Rural/Urban Classification",
    subtitle = "Based on CDPHE Health Statistics Region Designations",
    caption  = "Source: 2025 Colorado Health Access Survey (CHAS)"
  ) +
  theme_void(base_size = 13) +
  theme(
    plot.title    = element_text(face = "bold", hjust = 0.5, size = 15),
    plot.subtitle = element_text(hjust = 0.5, colour = "grey40"),
    plot.caption  = element_text(hjust = 1,  colour = "grey50", size = 9),
    legend.position   = "bottom",
    legend.title      = element_text(face = "bold"),
    plot.margin       = margin(10, 10, 10, 10)
  )

ggsave("map1_county_classification.png", map1,
       width = 11, height = 7.5, dpi = 300, bg = "white")
cat("\nMap 1 saved: map1_county_classification.png\n")


# ────────────────────────────────────────────────────────────
# MAP 2 – Health Statistics Regions (HSRs 1–21)
# ────────────────────────────────────────────────────────────

# Dissolve counties into HSR polygons
hsr_sf <- co_counties_sf %>%
  group_by(hsr) %>%
  summarise(geometry = st_union(geometry), .groups = "drop") %>%
  left_join(hsr_data %>% select(hsr, hsr_name, rural_urban), by = "hsr")

map2 <- ggplot() +
  # HSR fills
  geom_sf(data = hsr_sf,
          aes(fill = factor(hsr)),
          colour = "white", linewidth = 0.6) +
  # County borders (thin, semi-transparent)
  geom_sf(data = co_counties_sf,
          fill = NA, colour = "white", linewidth = 0.15, alpha = 0.5) +
  # HSR number labels
  geom_sf_text(data = hsr_centroids,
               aes(label = hsr),
               size = 3.2, fontface = "bold", colour = "white") +
  scale_fill_manual(
    values = hsr_palette,
    name   = "HSR",
    guide  = guide_legend(ncol = 7, title.position = "top")
  ) +
  labs(
    title    = "Colorado Health Statistics Regions (HSR 1–21)",
    subtitle = "Each region is composed of one or more counties",
    caption  = "Source: CDPHE / 2025 Colorado Health Access Survey (CHAS)"
  ) +
  theme_void(base_size = 13) +
  theme(
    plot.title    = element_text(face = "bold", hjust = 0.5, size = 15),
    plot.subtitle = element_text(hjust = 0.5, colour = "grey40"),
    plot.caption  = element_text(hjust = 1,  colour = "grey50", size = 9),
    legend.position   = "bottom",
    legend.title      = element_text(face = "bold"),
    plot.margin       = margin(10, 10, 10, 10)
  )

ggsave("map2_hsr_regions.png", map2,
       width = 11, height = 7.5, dpi = 300, bg = "white")
cat("Map 2 saved: map2_hsr_regions.png\n")


# ────────────────────────────────────────────────────────────
# MAP 3 – HSR Rural/Urban Designation + HSR number labels
# Fill reflects the HSR-level binary classification (Rural/Urban),
# with county borders shown faintly within each HSR.
# ────────────────────────────────────────────────────────────

hsr_rurban_palette <- c(
  "Urban" = "#2166AC",   # blue
  "Rural" = "#D6604D"    # red-orange
)

map3 <- ggplot() +
  # HSR fill = HSR-level Rural/Urban designation
  geom_sf(data = hsr_sf,
          aes(fill = rural_urban),
          colour = "#1a1a1a", linewidth = 0.7) +
  # County borders within HSRs (thin, light)
  geom_sf(data = co_counties_sf,
          fill = NA, colour = "white", linewidth = 0.2) +
  # HSR number labels at centroids
  geom_label(
    data = st_coordinates(hsr_centroids) %>%
      as_tibble() %>%
      bind_cols(hsr_centroids %>% st_drop_geometry()),
    aes(x = X, y = Y, label = hsr),
    size = 2.8, fontface = "bold",
    fill  = "white", colour = "#1a1a1a",
    label.size = 0.25, label.padding = unit(0.15, "lines"),
    alpha = 0.85
  ) +
  scale_fill_manual(
    values   = hsr_rurban_palette,
    name     = "HSR Classification",
    na.value = "grey80"
  ) +
  labs(
    title    = "Colorado Health Statistics Regions by Rural/Urban Designation",
    subtitle = "Fill = HSR-level classification  ·  Numbers = HSR ID",
    caption  = "Source: CDPHE / 2025 Colorado Health Access Survey (CHAS)"
  ) +
  theme_void(base_size = 13) +
  theme(
    plot.title    = element_text(face = "bold", hjust = 0.5, size = 15),
    plot.subtitle = element_text(hjust = 0.5, colour = "grey40", size = 10),
    plot.caption  = element_text(hjust = 1,  colour = "grey50", size = 9),
    legend.position   = "bottom",
    legend.title      = element_text(face = "bold"),
    plot.margin       = margin(10, 10, 10, 10)
  )

ggsave("map3_hsr_rural_urban.png", map3,
       width = 12, height = 8, dpi = 300, bg = "white")
cat("Map 3 saved: map3_hsr_rural_urban.png\n")

cat("\n=== Script complete. ===\n")
