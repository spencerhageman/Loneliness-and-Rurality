# ============================================================
# Colorado Loneliness & Urban/Rural Research Project
# Data: 2025 Colorado Health Access Survey (CHAS)
# ============================================================

library(tidyverse)
library(ggplot2)
library(sf)
library(tigris)      # For Colorado county shapefiles
library(scales)
library(ggrepel)     # For non-overlapping map labels

options(tigris_use_cache = TRUE)

# ============================================================
# SECTION 1: HSR RURAL/URBAN CLASSIFICATION
# ============================================================
# Health Statistics Regions (HSR 1–21) with county compositions
# and binary Rural/Urban classifications per CHAS definitions.
#
# Classification scheme (HSR level):
#   "Urban" – HSR is composed entirely of urban counties
#   "Rural" – HSR contains rural and/or rural resort counties
#             (Rural Resort is a county-level distinction only;
#              at the HSR level all non-urban regions = "Rural")
#
# Urban HSRs  : 2, 3, 4, 7, 14, 15, 16, 18, 19, 20, 21
# Rural HSRs  : 1, 5, 6, 8, 9, 10, 11, 12, 13, 17

hsr_data <- tribble(
  ~hsr, ~hsr_name,             ~counties,                                                          ~rural_urban,
  1,    "Northeast",           "Logan, Washington, Yuma, Phillips, Sedgwick, Morgan",              "Rural",
  2,    "Larimer",             "Larimer",                                                           "Urban",
  3,    "Douglas",             "Douglas",                                                           "Urban",
  4,    "El Paso",             "El Paso",                                                           "Urban",
  5,    "East Central",        "Lincoln, Elbert, Kit Carson, Cheyenne",                            "Rural",
  6,    "Southeast",           "Las Animas, Baca, Prowers, Bent, Kiowa, Otero, Crowley, Huerfano", "Rural",
  7,    "Pueblo",              "Pueblo",                                                            "Urban",
  8,    "San Luis Valley",     "Mineral, Costilla, Conejos, Alamosa, Saguache, Rio Grande",        "Rural",
  9,    "Southwest",           "Dolores, Montezuma, La Plata, San Juan, Archuleta",                "Rural",
  10,   "Western Slope",       "Gunnison, Delta, Montrose, Ouray, San Miguel, Hinsdale",           "Rural",
  11,   "Northwest",           "Jackson, Routt, Moffat, Rio Blanco",                               "Rural",
  12,   "Central Mountains",   "Garfield, Pitkin, Eagle, Summit, Grand",                           "Rural",
  13,   "Upper Arkansas",      "Lake, Chaffee, Fremont, Custer",                                   "Rural",
  14,   "Adams",               "Adams",                                                             "Urban",
  15,   "Arapahoe",            "Arapahoe",                                                          "Urban",
  16,   "Boulder/Broomfield",  "Boulder, Broomfield",                                              "Urban",
  17,   "Foothills",           "Park, Teller, Clear Creek, Gilpin",                                "Rural",
  18,   "Weld",                "Weld",                                                              "Urban",
  19,   "Mesa",                "Mesa",                                                              "Urban",
  20,   "Denver",              "Denver",                                                            "Urban",
  21,   "Jefferson",           "Jefferson",                                                         "Urban"
)

# Binary rural vs. urban variable (Urban = 0, Rural = 1)
hsr_data <- hsr_data %>%
  mutate(
    rural_binary = if_else(rural_urban == "Urban", 0L, 1L)
  )

cat("=== HSR Classification Table ===\n")
print(hsr_data %>% select(hsr, hsr_name, counties, rural_urban, rural_binary))

# ============================================================
