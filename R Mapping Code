  "Rio Blanco",    11,  "Rural",
  # ── HSR 12: Central Mountains (Rural Resort) ──────────────
  "Garfield",      12,  "Rural Resort",
  "Pitkin",        12,  "Rural Resort",
  "Eagle",         12,  "Rural Resort",
  "Summit",        12,  "Rural Resort",
