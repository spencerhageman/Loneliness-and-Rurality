  "Saguache",       8,  "Rural",
  "Rio Grande",     8,  "Rural",
  # ── HSR 9: Southwest (Rural Resort) ───────────────────────
  "Dolores",        9,  "Rural Resort",
  "Montezuma",      9,  "Rural Resort",
  "La Plata",       9,  "Rural Resort",
  "San Juan",       9,  "Rural Resort",
